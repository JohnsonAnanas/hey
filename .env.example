# Optionnel : RPC Base dédié (Alchemy/Infura/QuickNode) pour fiabilité/débit.
# Si absent, le scanner tombe sur des RPC publics (rate-limités mais suffisants pour prototyper).
RPC_URL_BASE=

# ─────────────────────────────────────────────────────────────────────────────
# Clés API CEX — LECTURE SEULE (statut dépôt/retrait des devises pour le filtre transferts)
# ⛔⛔ CE FICHIER (.env.example) EST UN TEMPLATE SUIVI PAR GIT — n'y mettre QUE des placeholders VIDES.
#     Les VRAIES clés vont UNIQUEMENT dans  arb/.env  (gitignoré), jamais ici, jamais dans le chat.
# Permissions sur l'exchange : "Read" / "Account info" UNIQUEMENT.
#   DÉSACTIVER : Trade, Withdraw, Transfer, Margin, Futures. (IP whitelist conseillée.)
#   Le compte peut être VIDE — on ne lit que le statut des devises. Remplir seulement ceux voulus.
# ─────────────────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=
OKX_API_KEY=
OKX_SECRET=
OKX_PASSWORD=            # OKX exige une passphrase
BYBIT_API_KEY=
BYBIT_SECRET=
KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSWORD=        # KuCoin exige une passphrase
GATEIO_API_KEY=
GATEIO_SECRET=
MEXC_API_KEY=
MEXC_SECRET=
BITGET_API_KEY=
BITGET_SECRET=
BITGET_PASSWORD=        # Bitget exige une passphrase
KRAKEN_API_KEY=
KRAKEN_SECRET=
HTX_API_KEY=
HTX_SECRET=
CRYPTOCOM_API_KEY=
CRYPTOCOM_SECRET=
